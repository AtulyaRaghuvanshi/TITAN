# Copy this file to .env if you want to run with real configuration.
# The system works in mock mode without any secrets.

APP_NAME="Multi-Agent Loan Approval System"
APP_HOST=0.0.0.0
APP_PORT=8010

# Keep empty for mock mode. Add a real key only if you wire an LLM prompt later.
OPENAI_API_KEY=

# Routing thresholds
MIN_CREDIT_SCORE=700
MAX_FOIR_PERCENT=50
MIN_MONTHLY_INCOME=25000

# Document verification
REQUIRE_PAN=true
REQUIRE_AADHAAR=true
REQUIRE_BANK_STATEMENT=true

# Output
SANCTION_OUTPUT_DIR=./generated_sanctions

